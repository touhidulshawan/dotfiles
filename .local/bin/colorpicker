#!/usr/bin/env bash

# Author: Touhidul Shawan
# Date Created: 28-03-2026
# Date Modified: 28-03-2026

# Description
# color picker that works on wayland. Just pick color value from selection and
# copy the value in clipboard

# Dependencies check
for cmd in grim slurp ffmpeg hexdump wl-copy notify-send; do
    if ! command -v "$cmd" >/dev/null 2>&1; then
        echo "Error: $cmd is not installed."
        exit 1
    fi
done

# Pick color
color=$(
    grim -g "$(slurp -p)" -t ppm - | \
    ffmpeg -i - -vf "crop=1:1:0:0,format=rgb24" -f rawvideo - 2>/dev/null | \
    hexdump -v -e '/1 "%02X"' | \
    sed 's/^/#/'
)

# Copy to clipboard
printf "%s" "$color" | wl-copy

# Send notification
notify-send "Color picked 🎨" "$color"
